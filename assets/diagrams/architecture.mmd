%%{init: {'theme': 'dark', 'themeVariables': { 'fontSize': '16px', 'fontFamily': 'JetBrains Mono' }}}%%

graph TB
    subgraph INTERNET["🌐 INTERNET"]
        USER[👤 Usuario]
        DNS[📡 DNS<br/>Cloudflare]
    end

    subgraph HETZNER["🖥️ HETZNER CLOUD - FSN1 Germany"]
        subgraph NETWORK["⚡ Network Layer"]
            PUB[46.224.204.126<br/>Public IPv4]
            PUB6[2a01:4f8:1c19:1cb3::1<br/>Public IPv6]
            VPN[Tailscale VPN<br/>100.77.1.30]
        end
        
        subgraph PERIMETER["🛡️ Security Perimeter"]
            CADDY[Caddy Reverse Proxy<br/>:443 HTTPS<br/>TLS 1.3 + Let's Encrypt]
        end
        
        subgraph AUTH["🔐 Authentication"]
            AUTHELIA[Authelia SSO<br/>:9091<br/>MFA + TOTP/WebAuthn]
        end
        
        subgraph APPS["☁️ Application Layer"]
            APACHE[Apache 2.4<br/>:8080]
            PHP[PHP 8.3 FPM<br/>Nextcloud 30.x]
            REDIS[(Redis 7.0<br/>Cache + Locks)]
        end
        
        subgraph DATA["💾 Data Layer"]
            MYSQL[(MySQL 8.0<br/>Database)]
            STORAGE1[Storage Box Ruben<br/>5TB CIFS/SMB]
            STORAGE2[Storage Box Manuel<br/>5TB CIFS/SMB]
        end
        
        subgraph OBSERV["📊 Observability"]
            GRAFANA[Grafana 12.4<br/>Dashboards]
            PROM[Prometheus<br/>Metrics]
        end
        
        subgraph SECRETS["🔑 Secrets"]
            VAULT[HashiCorp Vault<br/>:8200<br/>Secrets Manager]
        end
    end

    USER --> DNS
    DNS --> PUB
    DNS --> PUB6
    PUB --> CADDY
    PUB6 --> CADDY
    VPN -.->|Admin Access| CADDY
    
    CADDY -->|forward_auth| AUTHELIA
    AUTHELIA -->|Authenticated| APACHE
    APACHE --> PHP
    PHP --> REDIS
    PHP --> MYSQL
    PHP --> STORAGE1
    PHP --> STORAGE2
    
    CADDY -->|/grafana| GRAFANA
    GRAFANA --> PROM
    PROM --> MYSQL
    PROM --> REDIS
    PROM --> APACHE
    
    CADDY -->|/vault| VAULT
    VAULT -.->|Secrets| MYSQL
    VAULT -.->|Secrets| AUTHELIA

    style CADDY fill:#7aa2f7,stroke:#3d59a1,color:#1a1b26
    style AUTHELIA fill:#f7768e,stroke:#a13d4b,color:#1a1b26
    style MYSQL fill:#e0af68,stroke:#a07d3d,color:#1a1b26
    style REDIS fill:#bb9af7,stroke:#7d5aaa,color:#1a1b26
    style VAULT fill:#9ece6a,stroke:#5d7a3d,color:#1a1b26
